{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prime Client",
  "version": "1.0.0",
  "identifier": "gg.prime.PrimeClientLauncherV3",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "minecraft_auth": {},
    "updater": {
      "active": true,
      "endpoints": [],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5QkZBNTBGNjhDQTBGOEYKUldTUEQ4cG9ENlcvbVpVTVdnVkNNSGlXWXVXRklqcGFxNnBuRW1LM3VDTXpKcXU2MmdCNVc5S2IK"
    },
    "singleInstance": {
      "active": true
    },
    "deep-link": {
      "desktop": {
        "schemes": ["prime"]
      }
    },
    "cli": {
      "description": "Prime Client",
      "subcommands": {
        "launch": {
          "description": "Launch a profile with runtime-only overrides (does not persist)",
          "args": [
            { "name": "profile",        "short": "p", "takesValue": true, "required": true, "description": "Profile UUID or exact name" },
            { "name": "mc",                           "takesValue": true,                   "description": "Override game version, e.g. 1.21.11" },
            { "name": "loader",                       "takesValue": true,                   "description": "Override loader (vanilla|fabric|forge|neoforge|quilt)" },
            { "name": "loader-version",               "takesValue": true,                   "description": "Override loader version, e.g. 21.1.203" },
            { "name": "pack",                         "takesValue": true,                   "description": "Override Prime pack id" },
            { "name": "world",          "short": "w", "takesValue": true,                   "description": "Quick-play: join this singleplayer world on launch" },
            { "name": "server",         "short": "s", "takesValue": true,                   "description": "Quick-play: connect to this server address on launch" },
            { "name": "mods",                         "takesValue": true,                   "description": "Local mod jar(s) to load in-place (runtime-only): comma-separated paths, each a .jar file or a directory of jars" },
            { "name": "account",       "short": "a", "takesValue": true,                   "description": "Launch with this Minecraft account (username or UUID); defaults to the active account" }
          ]
        },
        "version": {
          "description": "Print launcher version and exit"
        },
        "temp": {
          "description": "Launch a throwaway MC instance (in-memory profile, no profiles.json entry; instance dir swept to trash on next launcher start)",
          "args": [
            { "name": "mc",             "short": "m", "takesValue": true, "required": true,  "description": "MC version, e.g. 26.1 or 1.21.11" },
            { "name": "loader",         "short": "l", "takesValue": true, "required": true,  "description": "vanilla|fabric|forge|neoforge|quilt" },
            { "name": "loader-version",               "takesValue": true,                    "description": "Optional explicit loader version (auto-resolved if omitted)" },
            { "name": "pack",                         "takesValue": true,                    "description": "Optional Prime pack id" },
            { "name": "name",                         "takesValue": true,                    "description": "Optional display name (default: temp-<short-uuid>)" },
            { "name": "world",          "short": "w", "takesValue": true,                    "description": "Quick-play: join this singleplayer world on launch" },
            { "name": "server",         "short": "s", "takesValue": true,                    "description": "Quick-play: connect to this server address on launch" },
            { "name": "mods",                         "takesValue": true,                    "description": "Local mod jar(s) to load in-place: comma-separated paths, each a .jar file or a directory of jars" },
            { "name": "account",       "short": "a", "takesValue": true,                    "description": "Launch with this Minecraft account (username or UUID); defaults to the active account" }
          ]
        }
      }
    }
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "PrimeClient",
        "width": 1280,
        "height": 800,
        "minWidth": 1080,
        "minHeight": 690,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": {
        "default-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost"
        ],
        "connect-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "data:",
          "https://api.iconify.design",
          "https://*.modrinth.com",
          "https://sessionserver.mojang.com",
          "https://*.prime.gg",
          "https://*.firebasedatabase.app",
          "https://primeclienttzt-default-rtdb.asia-southeast1.firebasedatabase.app"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "https://*.modrinth.com",
          "https://cdn.modrinth.com",
          "https://*.prime.gg",
          "https://textures.minecraft.net",
          "http://textures.minecraft.net",
          "https://crafatar.com",
          "https://media.forgecdn.net",
          "data:",
          "https://qr-generator-putuwaw.vercel.app",
          "https://i.ytimg.com",
          "https://img.youtube.com",
          "https://*.githubusercontent.com",
          "https://raw.githubusercontent.com",
          "https://i.imgur.com",
          "https://*.imgur.com",
          "https://discordapp.com",
          "https://cdn.discordapp.com",
          "https://*.gitlab.io",
          "https://gitlab.com",
          "https://mc-heads.net",
          "https://*.mc-heads.net",
          "https://wsrv.nl",
          "https://i.ibb.co",
          "https://media.githubusercontent.com",
          "https://avatars.githubusercontent.com",
          "https://pixelmonmod.com",
          "https://avatars.cloudhaven.gg"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'"
        ],
        "frame-src": [
          "'self'",
          "https://www.youtube.com",
          "https://www.youtube-nocookie.com",
          "https://player.vimeo.com"
        ]
      },
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": [
            "**/*"
          ]
        }
      }
    }
  },
  "bundle": {
    "publisher": "PrimeClient",
    "copyright": "Copyright © 2026 PrimeClient. All rights reserved.",
    "windows": {
      "webviewInstallMode": { "type": "skip" },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "compression": "none"
      }
    },
    "macOS": {
      "entitlements": "App.entitlements",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": "-",
      "dmg": {
        "background": "dmg/background.png",
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "height": 400,
          "width": 660
        }
      }
    },
    "active": true,
    "targets": [
      "app",
      "dmg",
      "deb",
      "appimage",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  }
}