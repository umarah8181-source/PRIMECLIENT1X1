{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prime Client Admin Panel",
  "version": "0.1.0",
  "identifier": "gg.prime.PrimeClientAdminPanel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1435",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Prime Client Admin Panel",
        "width": 1100,
        "height": 750,
        "center": true
      }
    ],
    "security": {
      "csp": {
        "default-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost"
        ],
        "connect-src": [
          "'self'",
          "https://*.is-best.net",
          "https://primeclient.is-best.net",
          "https://api.mcsrvstat.us",
          "https://catbox.moe"
        ],
        "img-src": [
          "'self'",
          "https://api.mcsrvstat.us",
          "data:"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
